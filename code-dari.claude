#include <WiFi.h>
#include <PubSubClient.h>
#include <ArduinoJson.h>
#include <OneWire.h>
#include <DallasTemperature.h>

// ==========================================
// KONFIGURASI WIFI DAN MQTT
// ==========================================
const char* WIFI_SSID     = "Cipika cipiki";
const char* WIFI_PASSWORD = "siapayaa";
const char* MQTT_HOST     = "10.219.134.213";
const uint16_t MQTT_PORT  = 1883;
const char* MQTT_TOPIC    = "heler/sensor";
const char* MQTT_CLIENT_ID = "esp32-heler-monitor";
const char* MQTT_USERNAME = "";
const char* MQTT_PASSWORD = "";

const float TANK_HEIGHT_CM            = 100.0;
const unsigned long PUBLISH_INTERVAL_MS = 250;
const unsigned long FLOW_SAMPLE_MS      = 250;
const unsigned long TEMPERATURE_SAMPLE_MS = 250;

// ==========================================
// KONFIGURASI SENSOR GETAR SW420
// ==========================================
// Polling interval: seberapa sering pin dibaca (ms)
const unsigned long VIBRATION_POLL_MS = 10;

// Window sampling: total durasi satu siklus penghitungan (ms)
// Lebih besar = lebih stabil, tapi lebih lambat respons
const unsigned long VIBRATION_WINDOW_MS = 1000;

// Jumlah slot dalam moving window (= WINDOW / POLL)
const int VIBRATION_WINDOW_SLOTS = VIBRATION_WINDOW_MS / VIBRATION_POLL_MS; // 100 slot

// Threshold HIGH count dalam satu window:
// Dikalibrasi saat boot, lalu ditambah margin
// Normal threshold: jika count > baseline + MARGIN_NORMAL → "Normal"
// Abnormal threshold: jika count > baseline + MARGIN_ABNORMAL → "Tidak Normal"
const int VIBRATION_MARGIN_NORMAL   = 5;   // HIGH count di atas baseline → mulai Normal
const int VIBRATION_MARGIN_ABNORMAL = 30;  // HIGH count di atas baseline → Tidak Normal

// Hysteresis: status tidak langsung turun, butuh konfirmasi beberapa window
const int HYSTERESIS_COUNT = 2; // berapa window berturut-turut sebelum status turun

// Mode debug Serial: set true untuk lihat raw data di Serial Monitor
#define VIBRATION_DEBUG true

// ==========================================
// DEFINISI PIN DOIT ESP32 V1
// ==========================================
#define DS18B20_PIN       13
#define WATER_FLOW_PIN    18
#define TRIG_PIN          5
#define ECHO_PIN          19
#define GETAR_PIN         23
#define BUZZER_PIN        27

#define LED_HIJAU_LEVEL   15
#define LED_MERAH_LEVEL   14
#define LED_HIJAU_FLOW    32
#define LED_MERAH_FLOW    33

// ==========================================
// OBJEK DAN VARIABEL GLOBAL
// ==========================================
OneWire oneWire(DS18B20_PIN);
DallasTemperature sensors(&oneWire);
WiFiClient espClient;
PubSubClient mqttClient(espClient);

// --- Flow sensor (tetap pakai interrupt, tidak diubah) ---
volatile unsigned int pulseCount = 0;
void IRAM_ATTR pulseCounter() { pulseCount++; }

unsigned long lastFlowCheckMs       = 0;
unsigned long lastPublishMs         = 0;
unsigned long lastTemperatureRequestMs = 0;
float currentFlowRate               = 0.0;

// --- Vibration: polling-based moving window ---
// Array circular buffer: menyimpan state pin tiap poll
int  vibrationBuffer[VIBRATION_WINDOW_SLOTS]; // 0 atau 1
int  vibrationBufferIndex  = 0;
int  vibrationHighCount    = 0;  // total HIGH dalam window saat ini
unsigned long lastVibrationPollMs = 0;
bool vibrationWindowFull   = false;
int  vibrationSlotsCount   = 0;  // slot yang sudah terisi

// Kalibrasi baseline (diisi saat boot)
int  vibrationBaseline     = 0;  // HIGH count rata-rata saat diam

// Hysteresis state
String currentVibrationStatus = "Tidak Bergetar";
int    statusDownCounter      = 0; // counter sebelum status diturunkan

// Suhu
float currentTemperature = 0.0;

// ==========================================
// STRUCT PAYLOAD
// ==========================================
struct SensorPayload {
  float  temperature;
  float  flowRate;
  float  waterLevel;
  float  distanceCm;
  int    vibrationRawPin;
  int    vibrationHighCount;
  int    vibrationBaseline;
  String vibrationStatus;
  String status;
};

// ==========================================
// KONEKSI WIFI & MQTT
// ==========================================
void connectToWiFi() {
  if (WiFi.status() == WL_CONNECTED) return;
  Serial.print("Menghubungkan WiFi");
  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  while (WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }
  Serial.println("\nWiFi terhubung. IP: " + WiFi.localIP().toString());
}

void connectToMqtt() {
  while (!mqttClient.connected()) {
    Serial.print("Menghubungkan MQTT... ");
    bool ok = (strlen(MQTT_USERNAME) > 0)
      ? mqttClient.connect(MQTT_CLIENT_ID, MQTT_USERNAME, MQTT_PASSWORD)
      : mqttClient.connect(MQTT_CLIENT_ID);
    if (ok) {
      Serial.println("berhasil");
    } else {
      Serial.print("gagal rc="); Serial.print(mqttClient.state());
      Serial.println(", coba lagi 5 detik");
      delay(5000);
    }
  }
}

// ==========================================
// ULTRASONIK & WATER LEVEL
// ==========================================
float readDistanceCm() {
  digitalWrite(TRIG_PIN, LOW);  delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH); delayMicroseconds(10);
  digitalWrite(TRIG_PIN, LOW);
  long dur = pulseIn(ECHO_PIN, HIGH, 30000);
  return (dur <= 0) ? TANK_HEIGHT_CM : dur * 0.034 / 2.0;
}

float calculateWaterLevelPercent(float distCm) {
  float lvl = ((TANK_HEIGHT_CM - distCm) / TANK_HEIGHT_CM) * 100.0;
  return constrain(lvl, 0.0, 100.0);
}

// ==========================================
// FLOW RATE (tidak diubah)
// ==========================================
void updateFlowRate() {
  unsigned long now = millis();
  if (now - lastFlowCheckMs < FLOW_SAMPLE_MS) return;
  noInterrupts();
  unsigned int pulses = pulseCount;
  pulseCount = 0;
  interrupts();
  currentFlowRate = (pulses == 0) ? 0.0 : ((1000.0 / (now - lastFlowCheckMs)) * pulses) / 7.5;
  lastFlowCheckMs = now;
}

// ==========================================
// SUHU (tidak diubah)
// ==========================================
void updateTemperature() {
  unsigned long now = millis();
  if (now - lastTemperatureRequestMs < TEMPERATURE_SAMPLE_MS) return;
  currentTemperature = sensors.getTempCByIndex(0);
  sensors.requestTemperatures();
  lastTemperatureRequestMs = now;
}

// ==========================================
// KALIBRASI VIBRATION SAAT BOOT
// Baca sensor selama durationMs dalam kondisi diam,
// hitung rata-rata HIGH count per window → simpan sebagai baseline.
// ==========================================
void calibrateVibration(unsigned long durationMs) {
  Serial.println("=== KALIBRASI SENSOR GETAR (jangan gerakkan mesin) ===");
  Serial.print("Durasi kalibrasi: ");
  Serial.print(durationMs / 1000);
  Serial.println(" detik...");

  unsigned long startMs    = millis();
  unsigned long pollTimer  = millis();
  int calBuffer[VIBRATION_WINDOW_SLOTS] = {0};
  int calIndex   = 0;
  int calSlots   = 0;
  int calHighSum = 0;
  int windowCount = 0;
  int windowHighSum = 0;

  while (millis() - startMs < durationMs) {
    if (millis() - pollTimer >= VIBRATION_POLL_MS) {
      pollTimer = millis();
      int pinState = digitalRead(GETAR_PIN);

      // Update circular buffer
      int oldVal = calBuffer[calIndex];
      calBuffer[calIndex] = pinState;
      calIndex = (calIndex + 1) % VIBRATION_WINDOW_SLOTS;
      if (calSlots < VIBRATION_WINDOW_SLOTS) calSlots++;

      calHighSum = calHighSum - oldVal + pinState;

      // Setiap satu window penuh, catat
      if (calSlots == VIBRATION_WINDOW_SLOTS &&
          calIndex == 0) { // setiap window selesai
        windowHighSum += calHighSum;
        windowCount++;
        Serial.print("  Window "); Serial.print(windowCount);
        Serial.print(": HIGH count = "); Serial.println(calHighSum);
      }
    }
    delay(1);
  }

  // Hitung baseline
  if (windowCount > 0) {
    vibrationBaseline = windowHighSum / windowCount;
  } else {
    // Fallback: hitung dari semua sample
    vibrationBaseline = calHighSum; // satu partial window
  }

  // Pastikan baseline tidak negatif
  if (vibrationBaseline < 0) vibrationBaseline = 0;

  Serial.print(">>> Baseline getar (diam): ");
  Serial.print(vibrationBaseline);
  Serial.println(" HIGH count/window");
  Serial.print(">>> Threshold Normal    : baseline + ");
  Serial.println(VIBRATION_MARGIN_NORMAL);
  Serial.print(">>> Threshold Abnormal  : baseline + ");
  Serial.println(VIBRATION_MARGIN_ABNORMAL);
  Serial.println("=== KALIBRASI SELESAI ===\n");
}

// ==========================================
// UPDATE VIBRATION: POLLING + MOVING WINDOW
// Dipanggil dari loop() setiap VIBRATION_POLL_MS.
// Mengisi circular buffer, hitung HIGH count dalam window.
// ==========================================
void updateVibration() {
  unsigned long now = millis();
  if (now - lastVibrationPollMs < VIBRATION_POLL_MS) return;
  lastVibrationPollMs = now;

  int pinState = digitalRead(GETAR_PIN);

  // --- Circular buffer update ---
  int oldVal = vibrationBuffer[vibrationBufferIndex];
  vibrationBuffer[vibrationBufferIndex] = pinState;
  vibrationBufferIndex = (vibrationBufferIndex + 1) % VIBRATION_WINDOW_SLOTS;

  if (vibrationSlotsCount < VIBRATION_WINDOW_SLOTS) {
    // Buffer belum penuh: hanya tambah, jangan kurangi oldVal
    vibrationHighCount += pinState;
    vibrationSlotsCount++;
  } else {
    // Buffer penuh: geser window (kurangi yang keluar, tambah yang baru)
    vibrationHighCount = vibrationHighCount - oldVal + pinState;
    vibrationWindowFull = true;
  }

  // --- Tentukan status hanya saat window sudah cukup terisi ---
  if (vibrationSlotsCount < VIBRATION_WINDOW_SLOTS / 2) return; // tunggu setengah window dulu

  int effectiveCount = vibrationHighCount - vibrationBaseline;

  // Thresholds relatif terhadap baseline
  int threshAbnormal = vibrationBaseline + VIBRATION_MARGIN_ABNORMAL;
  int threshNormal   = vibrationBaseline + VIBRATION_MARGIN_NORMAL;

  // Tentukan status baru dengan hysteresis
  String newStatus;
  if (vibrationHighCount >= threshAbnormal) {
    newStatus = "Terlalu Bergetar (Tidak Normal)";
    statusDownCounter = HYSTERESIS_COUNT; // reset hysteresis
  } else if (vibrationHighCount >= threshNormal) {
    newStatus = "Normal";
    statusDownCounter = HYSTERESIS_COUNT;
  } else {
    // Hanya turunkan status setelah beberapa window berturut-turut di bawah threshold
    if (statusDownCounter > 0) {
      statusDownCounter--;
      newStatus = currentVibrationStatus; // pertahankan status lama
    } else {
      newStatus = "Tidak Bergetar";
    }
  }

  currentVibrationStatus = newStatus;

  // --- Debug Serial ---
  #if VIBRATION_DEBUG
  static unsigned long lastDebugPrint = 0;
  if (now - lastDebugPrint >= 500) { // print setiap 500ms agar tidak flood
    lastDebugPrint = now;
    Serial.print("[GETAR DEBUG] pin="); Serial.print(pinState);
    Serial.print(" | highCount="); Serial.print(vibrationHighCount);
    Serial.print("/"); Serial.print(vibrationSlotsCount);
    Serial.print(" | baseline="); Serial.print(vibrationBaseline);
    Serial.print(" | threshN="); Serial.print(threshNormal);
    Serial.print(" | threshA="); Serial.print(threshAbnormal);
    Serial.print(" | status="); Serial.println(currentVibrationStatus);
  }
  #endif
}

// ==========================================
// STATUS MESIN: hanya dari sensor getar
// ==========================================
String resolveStatus(const String& vibrationStatus) {
  if (vibrationStatus == "Terlalu Bergetar (Tidak Normal)") return "Critical";
  if (vibrationStatus == "Normal")                          return "Warning";
  return "Optimal";
}

// ==========================================
// READ ALL SENSORS
// ==========================================
SensorPayload readSensors() {
  SensorPayload payload;
  updateFlowRate();
  updateTemperature();
  updateVibration(); // polling-based, aman dipanggil tiap loop

  payload.vibrationRawPin    = digitalRead(GETAR_PIN);
  payload.vibrationHighCount = vibrationHighCount;
  payload.vibrationBaseline  = vibrationBaseline;
  payload.vibrationStatus    = currentVibrationStatus;

  payload.distanceCm  = readDistanceCm();
  payload.waterLevel  = calculateWaterLevelPercent(payload.distanceCm);
  payload.flowRate    = currentFlowRate;
  payload.temperature = currentTemperature;
  payload.status      = resolveStatus(payload.vibrationStatus); // hanya dari getar
  return payload;
}

// ==========================================
// INDIKATOR LED & BUZZER
// ==========================================
void applyIndicators(const SensorPayload& payload) {
  bool levelRed   = (payload.distanceCm > 0 && payload.distanceCm <= 10.0);
  bool flowRed    = (payload.flowRate <= 0.0);
  bool buzzerOn   = (payload.vibrationStatus == "Terlalu Bergetar (Tidak Normal)");

  digitalWrite(LED_MERAH_LEVEL, levelRed  ? HIGH : LOW);
  digitalWrite(LED_HIJAU_LEVEL, !levelRed ? HIGH : LOW);
  digitalWrite(LED_MERAH_FLOW,  flowRed   ? HIGH : LOW);
  digitalWrite(LED_HIJAU_FLOW,  !flowRed  ? HIGH : LOW);
  digitalWrite(BUZZER_PIN,      buzzerOn  ? HIGH : LOW);
}

// ==========================================
// PRINT & PUBLISH
// ==========================================
void printSensorData(const SensorPayload& payload) {
  Serial.println("\n=== REAL-TIME SENSOR DATA MQTT ===");
  Serial.printf("Temperature      : %.2f C\n",      payload.temperature);
  Serial.printf("Water Flow Rate  : %.2f L/min\n",  payload.flowRate);
  Serial.printf("Water Distance   : %.2f cm\n",     payload.distanceCm);
  Serial.printf("Water Level      : %.2f %%\n",     payload.waterLevel);
  Serial.printf("Vibration Pin    : %d\n",           payload.vibrationRawPin);
  Serial.printf("Vibration High   : %d (baseline %d)\n",
                payload.vibrationHighCount, payload.vibrationBaseline);
  Serial.printf("Vibration Status : %s\n",           payload.vibrationStatus.c_str());
  Serial.printf("Machine Status   : %s\n",           payload.status.c_str());
}

void publishSensorData(const SensorPayload& payload) {
  StaticJsonDocument<320> doc;
  char buffer[320];

  doc["temperature"]       = payload.temperature;
  doc["flow_rate"]         = payload.flowRate;
  doc["water_level"]       = payload.waterLevel;
  doc["distance_cm"]       = payload.distanceCm;
  doc["vibration_value"]   = payload.vibrationRawPin;
  doc["vibration_count"]   = payload.vibrationHighCount;
  doc["vibration_status"]  = payload.vibrationStatus;
  doc["status"]            = payload.status;

  size_t len = serializeJson(doc, buffer);
  bool ok = mqttClient.publish(MQTT_TOPIC, buffer, len);
  Serial.print("Publish MQTT     : "); Serial.println(ok ? "berhasil" : "gagal");
  Serial.print("Payload JSON     : "); Serial.println(buffer);
}

// ==========================================
// SETUP
// ==========================================
void setup() {
  Serial.begin(115200);
  delay(500);

  pinMode(LED_HIJAU_LEVEL, OUTPUT);
  pinMode(LED_MERAH_LEVEL, OUTPUT);
  pinMode(LED_HIJAU_FLOW,  OUTPUT);
  pinMode(LED_MERAH_FLOW,  OUTPUT);
  pinMode(BUZZER_PIN,      OUTPUT);
  pinMode(TRIG_PIN,        OUTPUT);
  pinMode(ECHO_PIN,        INPUT);
  pinMode(GETAR_PIN,       INPUT);       // SW420: tidak perlu PULLUP (sudah ada onboard)
  pinMode(WATER_FLOW_PIN,  INPUT_PULLUP);

  // Inisialisasi buffer vibration ke 0
  memset(vibrationBuffer, 0, sizeof(vibrationBuffer));

  // Interrupt hanya untuk flow sensor
  attachInterrupt(digitalPinToInterrupt(WATER_FLOW_PIN), pulseCounter, FALLING);
  // Interrupt getar DIHAPUS — diganti polling

  sensors.begin();
  sensors.setResolution(9);
  sensors.setWaitForConversion(false);
  sensors.requestTemperatures();

  mqttClient.setServer(MQTT_HOST, MQTT_PORT);

  // Koneksi WiFi & MQTT dulu sebelum kalibrasi
  connectToWiFi();
  connectToMqtt();

  // Kalibrasi vibration 3 detik (pastikan mesin diam saat boot)
  calibrateVibration(3000);

  lastFlowCheckMs          = millis();
  lastPublishMs            = millis();
  lastTemperatureRequestMs = millis();
  lastVibrationPollMs      = millis();

  Serial.println("Sistem monitoring MQTT siap.");
}

// ==========================================
// LOOP
// ==========================================
void loop() {
  if (WiFi.status() != WL_CONNECTED) connectToWiFi();
  if (!mqttClient.connected())        connectToMqtt();
  mqttClient.loop();

  SensorPayload payload = readSensors();
  applyIndicators(payload);

  if (millis() - lastPublishMs >= PUBLISH_INTERVAL_MS) {
    printSensorData(payload);
    publishSensorData(payload);
    lastPublishMs = millis();
  }

  delay(10);
}